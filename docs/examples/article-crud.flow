# flow-dsl 1.0
flow "article-crud"
operations: "createArticle", "editArticle", "deleteArticle"

# Create article — extract id from Location and ETag for optimistic locking
call "createArticle"
  expect status "201"
extract articleId from response.header "Location" lastSegment
extract etag from response.header "ETag"

# Edit with If-Match from create
call "editArticle"
  path articleID = articleId
  header "If-Match" = etag
  expect status "2xx"

# Delete same article (sync 200/204)
call "deleteArticle"
  path articleID = articleId
  expect status "2xx"
